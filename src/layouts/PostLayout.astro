---
import Layout from "@layouts/Layout.astro";

interface Props {
  title: string;
  date?: string | Date;
  readingTime?: string;
  summary?: string;
  slug?: string;
  previousPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const { title, date, readingTime, summary, previousPost, nextPost } = Astro.props;

const dateValue = date
  ? date instanceof Date
    ? date
    : new Date(`${date}T00:00:00`)
  : null;

const formattedDate = dateValue
  ? dateValue.toLocaleDateString("en-US", {
      day: "numeric",
      month: "short",
      year: "numeric",
    })
  : null;
---

<Layout
  pageTitle={`${title} — Bilal Naeem`}
  pageDescription={summary}
  ogType="article"
  publishedTime={dateValue?.toISOString()}
>
  <article class="post-content py-12 md:py-16">
    <header class="space-y-4 border-b border-theme pb-8 md:pb-10">
      <a href="/posts" class="text-primary hover:text-primary-hover text-sm font-semibold">
        ← Back to writing
      </a>
      <h1 class="font-serif text-4xl font-semibold text-theme sm:text-5xl">
        {title}
      </h1>
      {summary && (
        <p class="text-theme-muted text-lg leading-relaxed">{summary}</p>
      )}
      {(formattedDate || readingTime) && (
        <div class="text-theme-muted flex flex-wrap items-center gap-3 text-sm">
          {formattedDate && (
            <time datetime={dateValue?.toISOString()}>
              {formattedDate}
            </time>
          )}
          {formattedDate && readingTime && <span>•</span>}
          {readingTime && <span>{readingTime}</span>}
        </div>
      )}
    </header>

    <div class="post-body mt-10">
      <slot />
    </div>
    {(previousPost || nextPost) && (
      <footer class="border-theme mt-12 grid gap-4 border-t pt-8 md:grid-cols-2">
        <div>
          {previousPost && (
            <a
              href={`/posts/${previousPost.slug}`}
              class="text-theme hover:text-primary block text-sm font-medium transition-colors"
            >
              <span class="text-theme-muted block text-xs uppercase">Previous</span>
              {previousPost.title}
            </a>
          )}
        </div>
        <div class="md:text-right">
          {nextPost && (
            <a
              href={`/posts/${nextPost.slug}`}
              class="text-theme hover:text-primary block text-sm font-medium transition-colors"
            >
              <span class="text-theme-muted block text-xs uppercase">Next</span>
              {nextPost.title}
            </a>
          )}
        </div>
      </footer>
    )}
  </article>
</Layout>
