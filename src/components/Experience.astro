---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";
import { SECTION_SUBTITLES } from "@config";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section
  text="Work Experience"
  href="experience"
  subtitle={SECTION_SUBTITLES.experience}
>
  {
    experience.map(({ company, position, startDate, endDate, summary }) => (
      <div class="mb-10">
        <h3 class="text-theme mb-1.5 font-serif text-2xl font-semibold">
          {company}
        </h3>
        <div class="flex flex-col items-start pb-5">
          <h4 class="text-primary mb-0.5 font-serif text-2xl font-medium">
            {position}
          </h4>
          <span class="text-theme-muted pb-[2px] text-sm">
            {startDate} — {endDate}
          </span>
        </div>
        {Array.isArray(summary) ? (
          <ul class="list-none">
            {summary.map((log) => (
              <li class="text-theme-muted relative mb-3 pl-8 text-base before:absolute before:top-1 before:left-0 before:content-[url(/check.svg)]">
                {log}
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-theme-muted text-base">{summary}</p>
        )}
      </div>
    ))
  }
</Section>
