---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";
import { SECTION_SUBTITLES } from "@config";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section
  text="Featured Projects"
  href="projects"
  subtitle={SECTION_SUBTITLES.projects}
>
  {
    projects.map(({ name, summary, image, linkPreview }, index) => {
      const top = 98 + index * 40;
      return (
        <div
          style={`top: ${top}px;`}
          class="group border-theme bg-theme hover:shadow-primary/10 mb-6 overflow-hidden rounded-2xl border transition-all duration-300 hover:shadow-xl md:sticky md:mb-10 md:rounded-3xl md:hover:-translate-y-0.5"
        >
          <div class="project-card-bg relative z-[1] grid min-h-[420px] w-full grid-rows-[auto_260px] rounded-2xl sm:min-h-[360px] sm:grid-cols-2 sm:grid-rows-1 md:h-96 md:rounded-3xl">
            <div class="relative z-10 px-5 py-6 md:px-8 md:py-10">
              <h3 class="text-theme group-hover:text-primary mb-3 font-serif text-xl font-semibold transition-colors duration-300 md:mb-4 md:text-3xl">
                {name}
              </h3>
              <p class="text-theme-muted text-sm leading-relaxed md:text-base">
                {summary}
              </p>
              {linkPreview ? (
                <a
                  href={linkPreview}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:text-primary-hover mt-4 inline-flex items-center gap-2 text-sm font-semibold"
                  aria-label={`Open ${name} case study on INFILP (new tab)`}
                >
                  View Case Study <span aria-hidden="true">↗</span>
                </a>
              ) : null}
            </div>
            <div class="relative min-h-[260px] w-full min-w-0 overflow-hidden sm:min-h-0">
              <img
                class="relative h-[260px] w-full border-0 object-cover object-top ring-0 outline-none max-sm:origin-top max-sm:scale-[1.12] sm:absolute sm:right-0 sm:-bottom-12 sm:left-auto sm:h-[190px] sm:w-[86%] sm:object-contain sm:object-center md:-right-16 md:-bottom-12 md:h-auto md:w-[95%]"
                src={image}
                alt={name}
                width="736"
                height="483"
                loading="eager"
              />
            </div>
          </div>
        </div>
      );
    })
  }
</Section>
