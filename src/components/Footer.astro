---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "socialLinks">;

const { socialLinks } = Astro.props;
---

<footer class="border-theme text-theme mx-auto w-full max-w-5xl border-t px-5 pt-8 pb-10 text-center md:px-8">
  <ul class="mb-2 flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm">
    {
      socialLinks.map(({ text, href }) => (
        <li>
          <a
            href={href}
            target={href.startsWith("mailto:") ? undefined : "_blank"}
            rel={href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
            class="text-theme-muted hover:text-primary inline-flex items-center gap-2 rounded-full px-4 py-2 transition-colors duration-200"
          >
            {text}
            {!href.startsWith("mailto:") && (
              <span aria-hidden="true" class="inline-block text-xs">↗</span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</footer>
