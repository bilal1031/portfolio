---
import Section from "./Section.astro";
import type { OpenSourceProjectProps } from "@types";
import { SECTION_SUBTITLES } from "@config";
import {
  fetchNpmLatestVersion,
  fetchNpmWeeklyDownloads,
  formatNpmDownloads,
  sortByNpmWeeklyDownloadsDesc,
} from "../utils/npm";

interface Props {
  openSourceProjects: OpenSourceProjectProps[];
}

const { openSourceProjects } = Astro.props;

type Enriched = OpenSourceProjectProps & {
  npmWeeklyDownloads: number | null;
  npmLatestVersion: string | null;
};

const enriched: Enriched[] = await Promise.all(
  openSourceProjects.map(async (p) => {
    if (!p.npmPackage) {
      return { ...p, npmWeeklyDownloads: null, npmLatestVersion: null };
    }
    const [npmWeeklyDownloads, npmLatestVersion] = await Promise.all([
      fetchNpmWeeklyDownloads(p.npmPackage),
      fetchNpmLatestVersion(p.npmPackage),
    ]);
    return { ...p, npmWeeklyDownloads, npmLatestVersion };
  }),
);

const sortedByWeeklyDownloads = sortByNpmWeeklyDownloadsDesc(enriched);
---

<Section
  text="Open Source"
  href="open-source"
  subtitle={SECTION_SUBTITLES.openSource}
>
  {
    enriched.length === 0 ? (
      <div class="border-theme bg-theme-secondary rounded-2xl border p-8 text-center">
        <p class="text-theme-muted text-base">
          Open-source projects will appear here once added.
        </p>
      </div>
    ) : (
      <div class="grid w-full grid-cols-1 gap-4 sm:grid-cols-2">
        {sortedByWeeklyDownloads.map(
          ({
            name,
            contribution,
            repository,
            homepage,
            tags,
            npmPackage,
            npmWeeklyDownloads,
            npmLatestVersion,
          }) => (
            <article class="border-theme bg-theme-secondary flex h-full flex-col rounded-2xl border p-5 md:p-6">
              <div class="flex h-[4rem] shrink-0 flex-col overflow-hidden">
                <h3
                  class="text-theme line-clamp-3 font-serif text-xl leading-snug font-semibold"
                  title={name}
                >
                  {name}
                </h3>
              </div>
              {tags && tags.length > 0 ? (
                <ul class="mt-3 flex flex-wrap gap-2" aria-label="Technologies">
                  {tags.map((tag) => (
                    <li>
                      <span class="border-theme text-theme-muted rounded-full border px-2.5 py-0.5 text-xs font-medium">
                        {tag}
                      </span>
                    </li>
                  ))}
                </ul>
              ) : null}
              {npmPackage &&
              (npmWeeklyDownloads !== null || npmLatestVersion) ? (
                <div class="text-theme-muted mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-xs">
                  <a
                    href={`https://www.npmjs.com/package/${encodeURIComponent(npmPackage)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:text-primary-hover font-semibold"
                    aria-label={`View ${npmPackage} on npm (new tab)`}
                  >
                    npm
                  </a>
                  {npmLatestVersion ? (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>v{npmLatestVersion}</span>
                    </>
                  ) : null}
                  {npmWeeklyDownloads !== null ? (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>~{formatNpmDownloads(npmWeeklyDownloads)}/wk</span>
                    </>
                  ) : null}
                </div>
              ) : null}
              <p class="text-theme-muted mt-2 text-sm leading-snug">
                {contribution}
              </p>
              <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
                <a
                  href={repository}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:text-primary-hover inline-flex items-center gap-2 text-sm font-semibold"
                  aria-label={`Open ${name} on GitHub (new tab)`}
                >
                  View on GitHub <span aria-hidden="true">↗</span>
                </a>
                {homepage ? (
                  <a
                    href={homepage}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary hover:text-primary-hover inline-flex items-center gap-2 text-sm font-semibold"
                    aria-label={`Open live demo for ${name} (new tab)`}
                  >
                    Live demo <span aria-hidden="true">↗</span>
                  </a>
                ) : null}
              </div>
            </article>
          ),
        )}
      </div>
    )
  }
</Section>
