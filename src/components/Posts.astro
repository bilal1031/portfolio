---
import Section from "./Section.astro";
import { getCollection } from "astro:content";
import { SECTION_SUBTITLES } from "@config";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = [...posts].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const featuredPosts = sortedPosts.slice(0, 4);

const formatDate = (value: Date) =>
  value.toLocaleDateString("en-US", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
---

<Section text="Writing" href="posts" subtitle={SECTION_SUBTITLES.posts}>
  {
    featuredPosts.length === 0 ? (
      <div class="border-theme bg-theme-secondary rounded-2xl border p-8 text-center">
        <p class="text-theme-muted text-base">
          No posts yet. Add your first story to make this section shine.
        </p>
      </div>
    ) : (
      <div class="space-y-4">
        {
          featuredPosts.map((post) => (
            <article class="border-theme bg-theme-secondary group rounded-2xl border p-5 transition-colors duration-200 hover:border-primary/40">
              <div class="text-theme-muted mb-2 flex flex-wrap items-center gap-2 text-xs">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.readingTime && (
                  <>
                    <span>•</span>
                    <span>{post.data.readingTime}</span>
                  </>
                )}
              </div>
              <a
                href={`/posts/${post.slug}`}
                class="text-theme group-hover:text-primary block font-serif text-2xl font-semibold transition-colors duration-200"
              >
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="text-theme-muted mt-2 text-base leading-relaxed">
                  {post.data.description}
                </p>
              )}
            </article>
          ))
        }
        <a
          href="/posts"
          class="text-primary hover:text-primary-hover inline-flex items-center gap-2 pt-4 text-sm font-semibold"
        >
          View all writing
          <span aria-hidden="true">→</span>
        </a>
      </div>
    )
  }
</Section>
