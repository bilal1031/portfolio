---
import type { HeroProps } from "@types";
import { SITE_CONFIG } from "@config";

type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;
const socialLinks = SITE_CONFIG.socialLinks.filter(
  (link) => link.text !== "Email",
);
---

<section
  class="relative py-20 md:py-28"
  id="hero"
  itemscope
  itemtype="https://schema.org/Person"
>
  <!-- Subtle background gradient -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
  </div>

  <div class="relative">
    <!-- Name -->
    <h1
      class="text-theme mb-4 max-w-4xl font-serif text-5xl font-semibold tracking-tight sm:text-6xl md:text-7xl"
      itemprop="name"
    >
      {name}
    </h1>

    <!-- Specialty with enhanced styling -->
    <p
      class="text-primary mb-6 max-w-3xl font-serif text-2xl leading-tight font-semibold tracking-tight sm:text-3xl md:mb-8 md:text-4xl"
      itemprop="jobTitle"
    >
      {specialty}
    </p>

    <!-- Summary with better typography and spacing -->
    <p
      class="text-theme-muted mb-12 max-w-2xl text-base leading-relaxed md:mb-14 md:text-lg"
      itemprop="description"
    >
      {summary}
    </p>

    <!-- CTA and Social Links -->
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:gap-6">
      <a
        class="group inline-flex items-center justify-center rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-primary/20 transition-all duration-200 ease-in-out hover:bg-primary-hover hover:shadow-xl hover:shadow-primary/30"
        href={`mailto:${email}`}
        itemprop="email"
        aria-label="Contact Bilal Naeem via email"
      >
        <span>Get in Touch</span>
        <svg
          class="ml-3 h-5 w-5 transition-transform duration-200 ease-in-out group-hover:translate-x-1"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>

      <!-- Social Media Links -->
      <div class="flex items-center gap-3">
        <div class="flex gap-4">
          {
            socialLinks.map((link) => {
              const isGitHub = link.text === "Github";
              const isLinkedIn = link.text === "LinkedIn";
              return (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group border-theme bg-theme-secondary relative flex h-11 w-11 items-center justify-center rounded-full border transition-all duration-300 hover:scale-105 hover:border-primary/40 hover:bg-primary/10 hover:shadow-lg hover:shadow-primary/20"
                  aria-label={`${link.text} Profile`}
                >
                  <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary/5 to-secondary/5 opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
                  {isGitHub ? (
                    <svg
                      class="text-theme-muted relative h-5 w-5 transition-all duration-300 group-hover:scale-110 group-hover:text-primary"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  ) : isLinkedIn ? (
                    <svg
                      class="text-theme-muted relative h-5 w-5 transition-all duration-300 group-hover:scale-110 group-hover:text-primary"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                  ) : null}
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Subtle fade-in animation for hero content */
  #hero h1,
  #hero p,
  #hero > div > div {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }

  #hero h1 {
    animation-delay: 0.1s;
  }

  #hero p[itemprop="jobTitle"] {
    animation-delay: 0.2s;
  }

  #hero p[itemprop="description"] {
    animation-delay: 0.3s;
  }

  #hero > div > div {
    animation-delay: 0.4s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Enhanced hover effects for CTA button */
  #hero a[href^="mailto:"] {
    position: relative;
    overflow: hidden;
  }

  #hero a[href^="mailto:"]::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.5s;
  }

  #hero a[href^="mailto:"]:hover::before {
    left: 100%;
  }
</style>
