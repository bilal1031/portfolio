---
interface Props {
  text: string;
  href: string;
  subtitle?: string;
}

const { text, href, subtitle } = Astro.props;
---

<section id={href} class="py-16 md:py-24">
  <div class="mb-10 md:mb-12">
    <p class="text-theme-muted mb-3 text-xs font-semibold tracking-[0.22em] uppercase">
      {text}
    </p>
    <h2
      class="text-theme mb-3 font-serif text-3xl font-semibold tracking-tight md:text-5xl"
    >
      {text}
    </h2>
    {
      subtitle && (
        <p class="text-theme-muted max-w-2xl text-base leading-relaxed md:text-lg">
          {subtitle}
        </p>
      )
    }
  </div>
  <slot />
</section>
